@inherits LayoutComponentBase

<div class="mm-wrapper">
    <nav class="navbar navbar-expand-lg mm-navbar">
        <div class="container">
            <a class="navbar-brand mm-brand d-flex align-items-center" href="/">
                <img src="/img/michoice-logo.png" alt="MiChoice" class="mm-logo me-2" />
                <span>MiMealMoney</span>
            </a>
            <button class="navbar-toggler text-white border-white" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="mainNav">
                <ul class="navbar-nav me-2">
                    <li class="nav-item">
                        <NavLink class="nav-link text-white" href="/menus">
                            <i class="bi bi-calendar3-week me-1"></i>School Menus
                        </NavLink>
                    </li>
                </ul>
                <NavMenu />
                <div class="ms-auto d-flex align-items-center">
                    <AuthorizeView>
                        <Authorized>
                            <span class="text-white me-3 small">
                                <i class="bi bi-person-circle me-1"></i>@context.User.Identity?.Name
                            </span>
                            <form method="post" action="/auth/logout" class="d-inline">
                                <AntiforgeryToken />
                                <button type="submit" class="btn btn-outline-light btn-sm">Sign Out</button>
                            </form>
                        </Authorized>
                        <NotAuthorized>
                            <a href="/auth/login" class="btn btn-outline-light btn-sm me-2">Sign In</a>
                            <a href="/auth/register" class="btn btn-light btn-sm mm-btn-register">Create Account</a>
                        </NotAuthorized>
                    </AuthorizeView>
                </div>
            </div>
        </div>
    </nav>

    <main class="mm-main">
        <div class="container py-4">
            @Body
        </div>
    </main>

    <footer class="mm-footer">
        <div class="container">
            <span class="text-muted small">
                &copy; @DateTime.Now.Year MiChoice · MiMealMoney &nbsp;|&nbsp;
                <a href="/privacy" class="text-muted">Privacy</a>
            </span>
        </div>
    </footer>
</div>
