<AuthorizeView>
    <Authorized>
        <ul class="navbar-nav">
            <li class="nav-item">
                <NavLink class="nav-link text-white" href="/" Match="NavLinkMatch.All">
                    <i class="bi bi-house me-1"></i>Home
                </NavLink>
            </li>
            <li class="nav-item">
                <NavLink class="nav-link text-white" href="/children">
                    <i class="bi bi-people me-1"></i>My Children
                </NavLink>
            </li>
            <li class="nav-item">
                <NavLink class="nav-link text-white" href="/pay">
                    <i class="bi bi-credit-card me-1"></i>Make a Payment
                </NavLink>
            </li>
            <li class="nav-item">
                <NavLink class="nav-link text-white" href="/history">
                    <i class="bi bi-clock-history me-1"></i>Transaction History
                </NavLink>
            </li>
            <li class="nav-item">
                <NavLink class="nav-link text-white" href="/settings">
                    <i class="bi bi-gear me-1"></i>Account Settings
                </NavLink>
            </li>
        </ul>

        <!-- District Admin section — only visible to Admin role -->
        <AuthorizeView Roles="Admin">
            <Authorized>
                <hr class="text-white-50 my-2" />
                <div class="text-white-50 text-uppercase small px-1 mb-1" style="font-size:.65rem;letter-spacing:.08em">
                    District Admin
                </div>
                <ul class="navbar-nav">
                    <li class="nav-item">
                        <NavLink class="nav-link text-white" href="/admin/accounts">
                            <i class="bi bi-search me-1"></i>Account Search
                        </NavLink>
                    </li>
                    <li class="nav-item">
                        <NavLink class="nav-link text-white" href="/admin/refunds">
                            <i class="bi bi-arrow-return-left me-1"></i>Refund Manager
                        </NavLink>
                    </li>
                </ul>
            </Authorized>
        </AuthorizeView>
    </Authorized>
</AuthorizeView>
